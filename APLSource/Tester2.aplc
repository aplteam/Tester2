                  ps.ref2Gui.‚ąÜn.Info.Text‚Üź'PAUSING'
                  {0=‚ćĶ.ref2Gui.‚ąÜn.PauseBtn.State:shy‚Üź1 ‚čĄ _‚Üź‚éēDL 0.3 ‚čĄ ‚ąá ‚ćĶ}ps
              :EndIf
              ¬Į1 ShowLog(length2‚ÜĎ(length‚ÜĎtestFns),' (',(cw 0‚ćēi),'/',max,')')
              i AddToGui(length2‚ÜĎ(length‚ÜĎ'  ',testFns),' (',(cw 0‚ćēi),'/',max,')')
              (continueFlag i noOf)‚ÜźHandleInitialize(ref ps currentGroup i noOf)
              :If continueFlag
                  HandleCleanup ref ps currentGroup i
                  :Continue
              :EndIf
              rc‚ÜźExecuteTestFunction ref ps testNo testFns
              :If ' '=1‚ÜĎ0‚ćīrc   ‚ćĚ Custom message?
                  :If (‚äārc)‚ąäListCustomMessages[;2]                      ‚ćĚ Is it a valid custom message?
                      rc‚Üź-‚ćé¬Į1‚ÜĎListSymbolicNames{‚äÉ‚ćļ[1‚ć≥‚ć®‚ćļ[;2]‚Č°¬®‚äā‚ćĶ;]}rc    ‚ćĚ Translate custom msg into return code
                  :Else
                      ‚éē‚Üź'Current test function (',testFns,')'
                      ‚éē‚Üź'returned an invalid result: neither a valid numeric code (symbolic name) nor a custom message'
                      ‚ąė‚ąė‚ąė
                  :EndIf
              :EndIf
              ps.totalCounter+‚Üź1
              ps.failedCounter+‚Üźrc=1
              :If 0>rc
                  ps.returnCodes,‚Üźrc
              :EndIf
              ps AddReturnCodeToGrid rc i
              comment‚Üź2‚Üďref GetFirstCommentLine testFns
              desc‚Üź‚äĘcomment
              :If rc‚ąä0 1
                  marker‚Üź('*‚úď'[1+rc=0])
              :Else
                  marker‚Üź'‚ćĚ'
              :EndIf
              3 ShowLog marker,' ',desc,ReportLineNumber
              i AddToGui(length2‚ÜĎ(length‚ÜĎmarker,' ',testFns),' (',(cw 0‚ćēi),'/',max,')'),' ‚ćĚ ',desc,ReportLineNumber
              ‚éēEX'‚ąÜFAILING_LINE'
              :If ~rc‚ąä_OK,_Failed
              :AndIf ps.guiFlag
              :AndIf ps.ref2Gui.‚ąÜn.‚ąÜClosed=0
                  (GetSymbolicName rc)ReportInactiveToGUI i ref testFns ps.ref2Gui.‚ąÜn
              :EndIf
              :If 0>rc
                  :If 0<ps.errCounter
                      rc‚Üź1
                  :EndIf
              :EndIf
          :Case QuitEvent
              HandleCleanup ref ps currentGroup i
              ‚éēSIGNAL QuitEvent
          :Else
              ps.errCounter+‚Üź1
              ps.totalCounter+‚Üź1
              comment‚Üź2‚Üďref GetFirstCommentLine testFns
              desc‚Üź‚äĘcomment
              marker‚Üź'#'
              ¬Į2 ShowLog marker' ',desc
              i AddToGui(length2‚ÜĎ(length‚ÜĎmarker,' ',testFns),' (',(cw 0‚ćēi),'/',max,')'),' ‚ćĚ ',desc
              :If ps.guiFlag
                  ps.ref2Gui.‚ąÜn.Grid.Values[i;4]‚Üź‚äā'{Broken}'
              :EndIf
          :EndTrap
          HandleCleanup ref ps currentGroup i
          {}‚éēWA  ‚ćĚ Enforce a memory compaction in order to get rid of any rubbish.
          :If ps.guiFlag
          :AndIf 0=ps.ref2Gui.‚ąÜn.‚ąÜClosed
              ps.stop‚Üź‚äÉ{‚ćĶ‚Č°(‚ČĘ‚ćĶ)‚ÜĎ1:0 ‚čĄ ‚ćĶ/0 1 2 4 3 5 7 6}ps.ref2Gui.‚ąÜn.Stop.SelItems
              ps.trapFlag‚Üźps.ref2Gui.‚ąÜn.TrapErrors.State
              ProcessGuiEvents ps.ref2Gui.‚ąÜn
          :AndIf ps.ref2Gui.‚ąÜn.‚ąÜClosed
              ‚éēSIGNAL QuitEvent
          :EndIf
      :Until i‚Č•‚ČĘps.list
      :If ps.guiFlag
          ps.ref2Gui.‚ąÜn.Info.Text‚Üź''
      :EndIf
‚ćĚDone
    ‚ąá

    ‚ąá HandleStops(fns ps StopHere testNo fnsName)
      :If 0<ps.stop
      :AndIf 1‚äÉ‚ĆĹ(8‚ćī2)‚ä§‚äÉps.stop
          (‚ą™(‚éēSTOP fns),StopHere)‚éēSTOP fns
          ‚éē‚Üź'About to execute <',(‚ćē_ref),'.',fnsName,'> ...'
      :Else
          ((‚éēSTOP fns)~StopHere)‚éēSTOP fns
      :EndIf
    ‚ąá

    ‚ąá (rc log)‚ÜźReportTestResults ps;noOf;constant;constants;comment
      log‚Üź''
      log,‚Üź‚äā'-----'
      log,‚Üź‚äā'  ',(‚ćēps.totalCounter),' test case',((1‚Č†ps.totalCounter)/'s'),' of ',(‚ćē‚ČĘps.list),' called'
      log,‚Üź‚äā'  ',(‚ćēps.failedCounter),' test case',((1‚Č†+/ps.failedCounter)/'s'),' failed',(0<ps.failedCounter)/' (flagged with "*")'
      log,‚Üź‚äā'  ',(‚ćēps.errCounter),' test case',((1‚Č†+/ps.errCounter)/'s'),' broken',(0<ps.errCounter)/' (flagged with "#")'
      :If 0‚Č†ps.totalCounter
          constants‚ÜźListSymbolicNames
          constants‚Üź(~constants[;1]‚ąä'_OK' '_Failed')‚ĆŅconstants
          :For constant comment :In ‚Üďconstants
              :If '_custom'{‚ćļ‚Č°(‚ČĘ‚ćļ)‚ÜĎ‚ćĶ}constant
              :AndIf 0<‚ČĘcomment
              :AndIf 0<noOf‚Üźps.returnCodes+.=-‚äÉ(//)‚éēVFI(‚ČĘ'_custom_')‚Üďconstant
                  log,‚Üź‚äā'  ',(‚ćēnoOf),' test cases not executed because of "',comment,'" (flagged with "‚ćĚ")'
              :ElseIf 0<noOf‚Üź+/ps.returnCodes‚ąä‚ćéconstant
                  log,‚Üź‚äā'  ',(‚ćēnoOf),' test cases not executed because of "',(1‚Üďconstant),'" (flagged with "‚ćĚ")'
              :EndIf
          :EndFor
      :Else
          log,‚Üź‚äā'0 test cases executed'
      :EndIf
      ShowLog log
      rc‚Üź0<ps.failedCounter+ps.errCounter
    ‚ąá

    ‚ąá {r}‚ÜźExecuteCleanup(ref ps);report;resultFlag;rc
      r‚Üź‚ć¨
      report‚Üź'Looking for a function "Cleanup": '
      :If 3=ref.‚éēNC'Cleanup'
          :If 3‚äÉ‚ĆĹ(8‚ćī2)‚ä§ps.stop
              (‚ąÜstop_before_cleanup_1 ‚ąÜstop_before_cleanup_2)‚éēSTOP 1‚äÉ‚éēSI
          :Else
              ((‚éēSTOP 1‚äÉ‚éēSI)~‚ąÜstop_before_cleanup_1 ‚ąÜstop_before_cleanup_2)‚éēSTOP 1‚äÉ‚éēSI
          :EndIf
          resultFlag‚Üź1 1‚äÉref.‚éēAT'Cleanup'
          rc‚Üź¬Į1 ‚ćĚ Undefined
          :Trap 0
              :If 0=1 2‚äÉref.‚éēAT'Cleanup'
     ‚ąÜstop_before_cleanup_1:  ‚ćĚ To switch off the stopping mechanism permanently, enter:   ps.stop‚Üź0
                  ‚ćé(resultFlag/'rc‚Üź'),'ref.Cleanup'
              :Else
     ‚ąÜstop_before_cleanup_2:  ‚ćĚ To switch off the stopping mechanism permanently, enter:   ps.stop‚Üź0
                  ‚ćé(resultFlag/'rc‚Üź'),'ref.Cleanup ps'
              :EndIf
          :Else
              report,‚Üź' found but crashed (',‚éēDMX.EM,')'
              ShowLog report
              :Return
          :EndTrap
          :Select ‚äÉrc
          :Case ¬Į1
              report,‚Üź' found and executed'
          :Case 1
              report,‚Üź' found and executed successfully'
          :Case 0
              report,‚Üź' found and executed but indicated failure by its result'
          :Else
              report,‚Üź' found and executed but returned an invalid result'
          :EndSelect
      :Else
          report,‚Üź'not found'
      :EndIf
      ShowLog report
    ‚ąá

    ‚ąá rc‚ÜźExecuteTestFunction(ref ps testNo fnsName);buff
      :If 0=ps.batchFlag
      :AndIf 0=+/'‚éēTRAP'‚ć∑1 ‚éēC{‚ćĶ‚ÜĎ‚ć®‚ćĶ‚ć≥'‚ćĚ'}{‚äÉ,/‚ćĶ‚ÜĎ‚ć®1++/‚ąß\';'=1‚Üď‚äÉ¬®A.DLB ‚ćĶ}ref.‚éēNR fnsName
          ShowLog'  *** WARNING: ‚éēTRAP is not localized in ',(‚ćēref),'.',fnsName
      :EndIf
      :If 0<‚ČĘ_codeCoverage
          _codeCoverage.Start ‚ć¨
      :EndIf
      HandleStops(1‚äÉ‚éēSI)ps ‚ąÜstop_before_test testNo fnsName

          ‚éēEX'‚ąÜTRAPS_IN_SESSION'
      :EndIf
      :If ps.guiFlag
      :AndIf {6::1 ‚čĄ 0‚ä£‚ćĶ.Type}ps.ref2Gui.‚ąÜn.Form

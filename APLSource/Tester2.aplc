      :If 0=‚ČĘps.list‚Üź{‚ćĶ[;1]}ListTestFunctions''
          ‚Üí‚ąÜGetOutOfHere,rc‚Üź0
      :EndIf
      ProcessGroupAndTestCaseNumbers(_ref ps)
      :If 0=‚ČĘps.list
          ‚Üí‚ąÜGetOutOfHere,rc‚Üź0
      :EndIf
      ‚Üí(0=‚ČĘps.list)/‚ąÜGetOutOfHere
      :If ps.guiFlag
          :If 0<‚ČĘps.list
              ps.ref2Gui.‚ąÜn.Grid.Values[‚ć≥‚ČĘps.list;2]‚Üź(‚ČĘ'Test_')‚Üď¬®ps.list
              ps.ref2Gui.‚ąÜn.Grid.Values[‚ć≥‚ČĘps.list;3]‚Üź2‚Üď¬®_ref GetFirstCommentLine¬®ps.list
              {2 ‚éēNQ ps.ref2Gui.‚ąÜn.Grid'SetColSize'‚ćĶ ¬Į3}¬®2 3
          :EndIf
          {}{_‚Üź‚éēDQ ‚ćĶ ‚čĄ ‚éēDL 0.1}‚ć£(0=TestFlag)‚ä£ps.ref2Gui.‚ąÜn.Form
          :If ps.ref2Gui.‚ąÜn.‚ąÜClosed

              ps.list‚Üź''
              ‚Üí‚ąÜGetOutOfHere
          :Else
              rc‚Üź0
          :EndIf
      :EndIf
      ps.returnCodes‚Üź‚ć¨
      ps.processedGroups‚Üź''
      ShowLog(,'--- Tests started at ',A.FormatDateTime ‚éēTS),' on ',(‚ćē_ref),' ---'
      buff‚Üź‚ĆĹ(8‚ćī2)‚ä§ps.stop
      :If 0<‚ČĘps.testCaseNos
          buff[1]‚ą®‚Üź¬Į1‚ąä√óps.testCaseNos
      :EndIf
      ps.stop‚Üź2‚ä•‚ĆĹbuff

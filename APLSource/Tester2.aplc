          :EndIf
          :Select ‚äÉ(‚éēIO+1)‚äÉ1 ref.‚éēAT'Initial'
          :Case 0
              :If 0=‚äÉ‚äÉref.‚éēAT'Initial'
     ‚ąÜstop_before_initial_1:  ‚ćĚ To switch off the stopping mechanism permanently, enter:   ps.stop‚Üź0
                  ref.Initial
              :Else
     ‚ąÜstop_before_initial_2:  ‚ćĚ To switch off the stopping mechanism permanently, enter:   ps.stop‚Üź0
                  buff‚Üźref.Initial
                  :If ' '=1‚ÜĎ0‚ćībuff
                      success‚Üź0=‚ČĘbuff
                      :If 0<‚ČĘbuff
                          initMsg‚Üźbuff
                      :EndIf
                  :Else
                      success‚Üźbuff
                  :EndIf
              :EndIf
          :Case 1
              :If 0=‚äÉ‚äÉref.‚éēAT'Initial'
     ‚ąÜstop_before_initial_3:  ‚ćĚ To switch off the stopping mechanism permanently, enter:   ps.stop‚Üź0
                  ref.Initial ps
              :Else
     ‚ąÜstop_before_initial_4:  ‚ćĚ To switch off the stopping mechanism permanently, enter:   ps.stop‚Üź0
                  buff‚Üźref.Initial ps
                  :If ' '=1‚ÜĎ0‚ćībuff
                      success‚Üź0=‚ČĘbuff
                      :If 0<‚ČĘbuff
                          initMsg‚Üźbuff
                      :EndIf
                  :Else
                      success‚Üźbuff
                  :EndIf
              :EndIf
          :Else
              11 ‚éēSIGNAL‚ć®'The "Initial" function in ',(‚ćēref),' has an invalid signature: it''s neither monadic nor niladic'
          :EndSelect
          :If success
              report,‚Üź'found and executed successfully'
          :Else
              report,‚Üź'found and executed but it signalled failure'
              :If 0<‚ČĘinitMsg
                  report,‚Üź':',CR,initMsg
              :EndIf
          :EndIf
      :Else
          report,‚Üź'not found'
      :EndIf
      ShowLog report
